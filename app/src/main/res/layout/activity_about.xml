<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/about_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="#c8ff01">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/app_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lalu Lintas App"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#171717"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/app_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Versi 1.0"
                android:textSize="14sp"
                android:textColor="#171717"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/app_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplikasi ini menggunakan model machine learning (TensorFlow Lite) untuk mendeteksi kondisi lalu lintas berdasarkan input fitur pengguna."
                android:textSize="16sp"
                android:textColor="#171717"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/app_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dibuat oleh: Khafidh Ilham C.G"
                android:textSize="15sp"
                android:textColor="#171717"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/app_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Purwakarta, Jawa Barat"
                android:textSize="15sp"
                android:textColor="#171717"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
